# ============================================
# READOUT - ROOT ENVIRONMENT VARIABLES
# Copy to .env and fill in values
# ============================================

NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/readout_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-strong-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-too
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=readout-media

# Service Ports
USER_API_PORT=5000
ADMIN_API_PORT=5001
AI_ENGINE_PORT=5002
SCRAPER_PORT=5003
NOTIFICATION_PORT=5004

# Internal Service URLs (for inter-service calls)
AI_ENGINE_URL=http://localhost:5002
NOTIFICATION_URL=http://localhost:5004
